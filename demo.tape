Output demo.gif

Set Shell "bash"
Set FontSize 14
Set Width 900
Set Height 600
Set Padding 20
Set Theme "Dracula"
Set TypingSpeed 40ms

# Scan
Type "./skel scan my-setup"
Enter
Sleep 4s

# Show
Type "./skel show my-setup"
Enter
Sleep 4s

# Drift
Type "./skel drift my-setup"
Enter
Sleep 3s

# Dry run restore
Type "./skel restore my-setup --dry-run"
Enter
Sleep 4s

# Publish
Type "./skel publish my-setup"
Enter
Sleep 3s

Sleep 2s
